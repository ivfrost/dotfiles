{
	"window.commandCenter": false,
	"workbench.layoutControl.enabled": false,
	"workbench.activityBar.location": "bottom",
	"window.menuBarVisibility": "toggle",
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"editor.formatOnSave": true,
	"prettier.bracketSameLine": true,
	"prettier.experimentalTernaries": true,
	"prettier.singleQuote": true,
	"prettier.useTabs": true,
	"prettier.vueIndentScriptAndStyle": true,
	"github.copilot.chat.localeOverride": "en",
	"github.copilot.nextEditSuggestions.enabled": false,
	"editor.fontFamily": "BlexMono Nerd Font",
	"explorer.compactFolders": false,
	"github.copilot.nextEditSuggestions.fixes": false,
	"github.copilot.enable": {
		"*": true,
		"plaintext": false,
		"markdown": true,
		"scminput": false,
		"typescriptreact": true,
	},
	"C_Cpp.clang_format_style": "file",
	"C_Cpp.clang_format_fallbackStyle": "Google",
	"window.restoreWindows": "all",
	"window.title": "${rootName} — ${appName}",

	"prettier.tabWidth": 2,
	"python.analysis.autoImportCompletions": true,
	"python.analysis.autoFormatStrings": true,
	"python.analysis.completeFunctionParens": true,
	"python.analysis.typeCheckingMode": "basic",
	"git.openRepositoryInParentFolders": "never",
	"editor.autoClosingBrackets": "always",
	"workbench.iconTheme": "material-icon-theme",
	"extensions.ignoreRecommendations": true,
	"explorer.confirmDragAndDrop": false,
	"editor.multiCursorModifier": "alt",
	"extensions.experimental.affinity": {
		"asvetliakov.vscode-neovim": 1,
	},
	"chat.fontFamily": "Adwaita Sans",
	"notebook.markup.fontFamily": "BlexMono Nerd Font",
	"markdown.preview.fontFamily": "'Adwaita Sans',  system-ui, 'Ubuntu', 'Droid Sans', sans-serif",
	"editor.parameterHints.enabled": false,
	"workbench.editor.empty.hint": "hidden",
	"editor.tabSize": 2,
	"chat.viewSessions.orientation": "stacked",
	"keyboard.dispatch": "keyCode",
	"terminal.integrated.fontLigatures.enabled": false,
	"editor.fontLigatures": false,
	"window.titleBarStyle": "custom",
	"editor.renderLineHighlight": "none",
	"window.controlsStyle": "custom",
	"scm.inputFontSize": 14,
	"window.customTitleBarVisibility": "windowed",
	"window.enableMenuBarMnemonics": false,
	"workbench.editor.enablePreview": false,
	"editor.fontWeight": "400",
	"editor.lineHeight": 1.4,
	"editor.allowVariableFonts": false,
	"chat.fontSize": 14,
	"workbench.editor.closeOnFileDelete": true,
	"workbench.editor.labelFormat": "medium",
	"workbench.preferredLightColorTheme": "Light+",
	"window.autoDetectColorScheme": true,
	"editor.stickyScroll.enabled": true,
	"search.exclude": {
		"**/node_modules": true,
		"**/dist": true,
		"**/build": true,
		"**/.git": true,
	},
	"json.schemaDownload.trustedDomains": {
		"https://schemastore.azurewebsites.net/": true,
		"https://raw.githubusercontent.com/": true,
		"https://www.schemastore.org/": true,
		"https://json.schemastore.org/": true,
		"https://json-schema.org/": true,
		"https://biomejs.dev": true,
	},
	"editor.codeActionsOnSave": {
		"source.organizeImports.biome": "explicit",
		"source.fixAll.biome": "explicit",
	},
	"workbench.preferredDarkColorTheme": "Dark+",
	"workbench.colorCustomizations": {
		"tab.activeBorder": "#d4d4d4",
		"editorIndentGuide.background1": "#3a3a3a",
		"editorIndentGuide.activeBackground1": "#555555",
	},
	"chat.tools.global.autoApprove": false,
	"terminal.integrated.fontFamily": "BlexMono Nerd Font",
	"editor.minimap.enabled": false,
	"workbench.browser.openLocalhostLinks": false,
	"tailwindCSS.experimental.classRegex": [
		["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]* archival)[\"'`]"],
	],
	"files.associations": {
		"*.css": "tailwindcss",
		"*.scss": "tailwindcss",
	},
	"js/ts.suggest.autoImports": true,
	"editor.scrollBeyondLastColumn": 0,
	"editor.rulers": [
		{ "column": 80, "color": "#2a2a2a" },
		{ "column": 120, "color": "#2a2a2a" },
	],
}
