[
	{
		"layer": "top",
		"position": "top",
		"exclusive": true,
		"spacing": 10,
		"margin": 0,
		"modules-left": [
			"sway/workspaces",
			"sway/mode",
			"sway/window"
		],
		"modules-center": [
			"clock",
			"custom/theme"
		],
		"modules-right": [
			"tray",
			"keyboard-state",
			"mpd",
			"cpu",
			"memory",
			"backlight",
			"pulseaudio",
			"custom/network",
			"custom/power"
		],
		"keyboard-state": {
			"numlock": false,
			"capslock": true,
			"format": "{icon}",
			"format-icons": {
				"locked": "юФ▒",
				"unlocked": ""
			},
			"empty-format": ""
		},
		"sway/workspaces": {
			"format": "<span size='12pt'>{icon}</span>",
			"all-outputs": true,
			"format-icons": {
				"1": "юВУ",
				"2": "юГи",
				"3": "юЧХ",
				"4": "юДЦ",
				"5": "юБЮ",
				"6": "юВА",
				"7": "юЪГ",
				"8": "юГХ",
				"9": "юБ╢",
				"10": "юБ╢"
			}
		},
		"sway/mode": {
			"format": "<span style=\"italic\">{}</span>"
		},
		"sway/scratchpad": {
			"format": "{icon} {count}",
			"show-empty": false,
			"format-icons": [
				"",
				"яЛТ"
			],
			"tooltip": true,
			"tooltip-format": "{app}: {title}"
		},
		"mpd": {
			"format": "яАБ  {title} - {artist} {stateIcon} [{elapsedTime:%M:%S}/{totalTime:%M:%S}] {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}[{songPosition}/{queueLength}] [{volume}%]",
			"format-disconnected": "яАБ Disconnected",
			"format-stopped": "яАБ {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped",
			"unknown-tag": "N/A",
			"interval": 2,
			"consume-icons": {
				"on": "яГД "
			},
			"random-icons": {
				"on": "яБ┤ "
			},
			"repeat-icons": {
				"on": "яАЮ "
			},
			"single-icons": {
				"on": "яАЮ1 "
			},
			"state-icons": {
				"paused": "яБМ",
				"playing": "яБЛ"
			},
			"tooltip-format": "MPD (connected)",
			"tooltip-format-disconnected": "MPD (disconnected)",
			"on-click": "mpc toggle",
			"on-click-right": "foot -a ncmpcpp ncmpcpp",
			"on-scroll-up": "mpc volume +2",
			"on-scroll-down": "mpc volume -2"
		},
		"idle_inhibitor": {
			"format": "{icon}",
			"format-icons": {
				"activated": "яБо",
				"deactivated": "яБ░"
			}
		},
		"tray": {
			"spacing": 10
		},
		"clock": {
			"format": "{:%a %d %b %H:%M}",
			"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
		},
		"cpu": {
			"format": "<span rise='-3pt' size='12pt'>{icon}</span> <span>{usage}%</span>",
			"format-icons": [
				"юВй"
			]
		},
		"memory": {
			"format": "<span rise='-3pt' size='12pt'>юДХ</span> {}%"
		},
		"temperature": {
			"thermal-zone": 2,
			"hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
			"critical-threshold": 80,
			"format-critical": "{icon} {temperatureC}┬░C",
			"format": "{icon} {temperatureC}┬░C",
			"format-icons": [
				"яЭл",
				"яЛЙ",
				"яЭй"
			]
		},
		"backlight": {
			"format": "<span rise='-3pt' size='12pt'>{icon}</span> {percent}%",
			"format-icons": [
				"юК▒"
			],
			"tooltip": false
		},
		"custom/network": {
			"exec": "~/.config/waybar/scripts/network.sh",
			"interval": 5,
			"return-type": "json",
			"tooltip": true,
			"on-click": "nm-connection-editor"
		},
		"pulseaudio": {
			"scroll-step": 5,
			"format": "<span rise='-3pt' size='12pt'>{icon}</span>{volume}%┬а┬а┬а┬а{format_source}",
			"format-bluetooth": "юБЬ {icon} {volume}% {format_source}",
			"format-bluetooth-muted": "яЪй яКФ {icon} {format_source}",
			"format-muted": "<span rise='-3pt' size='12pt'>юШж</span>┬а┬а┬а┬а{format_source}",
			"format-source": "<span rise='-3pt' size='12pt'>юДШ┬а</span>{volume}%",
			"format-source-muted": "<span rise='-3pt' size='12pt'>юДЩ</span>",
			"format-icons": {
				"default": [
					"юЖк",
					"юЖл┬а"
				]
			},
			"on-click": "pavucontrol",
			"on-click-right": "foot -a pw-top pw-top"
		},
		"custom/power": {
			"format": "<span size='12pt'>юЕА</span>",
			"tooltip": false,
			"menu": "on-click",
			"menu-file": "~/.config/waybar/power_menu.xml",
			"menu-actions": {
				"shutdown": "systemctl poweroff",
				"reboot": "systemctl reboot",
				"suspend": "systemctl suspend",
				"lock": "swaylock",
				"logout": "swaymsg exit"
			}
		},
		"custom/theme": {
			"format": "<span size='12pt'>юК▓</span>",
			"format-icons": {
				"default": "юК▓"
			},
			"tooltip": "Toggle theme",
			"on-click": "~/.config/waybar/scripts/toggle-theme.sh"
		},
		"custom/battery": {
			"exec": "~/.config/waybar/scripts/battery.sh",
			"interval": 5,
			"return-type": "json",
			"tooltip": true
		}
	}
]
