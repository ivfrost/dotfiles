[
	{
		"layer": "top",
		"position": "top",
		"exclusive": true,
		"spacing": 4,
		"margin": 0,
		"modules-left": [
			"sway/workspaces",
			"sway/mode",
			"sway/window"
		],
		"modules-center": [
			"clock",
			"custom/notification"
		],
		"modules-right": [
			"tray",
			"keyboard-state",
			"mpd",
			"custom/backlight",
			"custom/keyboard",
			"pulseaudio",
			"custom/network",
			"custom/battery",
			"custom/power"
		],
		"keyboard-state": {
			"numlock": false,
			"capslock": true,
			"format": "{icon}",
			"format-icons": {
				"locked": "",
				"unlocked": ""
			},
			"empty-format": ""
		},
		"sway/workspaces": {
			"format": "{icon}",
			"all-outputs": true,
			"format-icons": {
				"1": "юГ┤",
				"2": "юЖ╛",
				"3": "юЙЪ",
				"4": "юЕи",
				"5": "юГв",
				"6": "юПТ",
				"7": "юа╛",
				"8": "юЮЮ",
				"9": "юБ╢",
				"10": "юБ╢"
			}
		},
		"sway/mode": {
			"format": "<span style=\"italic\">{}</span>"
		},
		"sway/scratchpad": {
			"format": "{icon} {count}",
			"show-empty": false,
			"format-icons": [
				"",
				"яЛТ"
			],
			"tooltip": true,
			"tooltip-format": "{app}: {title}"
		},
		"mpd": {
			"format": "яАБ  {title} - {artist} {stateIcon} [{elapsedTime:%M:%S}/{totalTime:%M:%S}] {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}[{songPosition}/{queueLength}] [{volume}%]",
			"format-disconnected": "яАБ Disconnected",
			"format-stopped": "яАБ {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped",
			"unknown-tag": "N/A",
			"interval": 2,
			"consume-icons": {
				"on": "яГД "
			},
			"random-icons": {
				"on": "яБ┤ "
			},
			"repeat-icons": {
				"on": "яАЮ "
			},
			"single-icons": {
				"on": "яАЮ1 "
			},
			"state-icons": {
				"paused": "яБМ",
				"playing": "яБЛ"
			},
			"tooltip-format": "MPD (connected)",
			"tooltip-format-disconnected": "MPD (disconnected)",
			"on-click": "mpc toggle",
			"on-click-right": "foot -a ncmpcpp ncmpcpp",
			"on-scroll-up": "mpc volume +2",
			"on-scroll-down": "mpc volume -2"
		},
		"idle_inhibitor": {
			"format": "{icon}",
			"format-icons": {
				"activated": "яБо",
				"deactivated": "яБ░"
			}
		},
		"tray": {
			"spacing": 10
		},
		"clock": {
			"format": "{:%a %d %b %H:%M}",
			"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
		},
		"cpu": {
			"format": "",
			"format-icons": [
				"юВй"
			]
		},
		"memory": {
			"format": " {}%"
		},
		"temperature": {
			"thermal-zone": 2,
			"hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
			"critical-threshold": 80,
			"format-critical": "{icon} {temperatureC}┬░C",
			"format": "{icon} {temperatureC}┬░C",
			"format-icons": [
				"яЭл",
				"яЛЙ",
				"яЭй"
			]
		},
		"backlight": {
			"format": " {percent}%",
			"format-icons": [
				""
			],
			"tooltip": false
		},
		"custom/backlight": {
			"exec": "cat /tmp/waybar-brightness.json 2>/dev/null || echo '{}'",
			"return-type": "json",
			"interval": 1,
			"format": " {text}",
			"tooltip": false
		},
		"custom/keyboard": {
			"exec": "cat /tmp/keyboard-popup.json 2>/dev/null || echo '{}'",
			"return-type": "json",
			"interval": 1,
			"format": "{text}",
			"tooltip": false
		},
		"custom/network": {
			"exec": "~/.config/waybar/scripts/network.sh",
			"interval": 5,
			"return-type": "json",
			"tooltip": true,
			"on-click": "nm-connection-editor"
		},
		"pulseaudio": {
			"scroll-step": 5,
			"format": "<span size='16pt' weight='600' rise='-4pt'>юКж</span>┬а┬а{volume}%",
			"format-bluetooth": "юГЪ {icon} {volume}% {format_source}",
			"format-bluetooth-muted": "юГЪ {icon} {format_source}",
			"format-muted": "<span size='16pt' weight='600' rise='-4pt'>юСЦ</span>┬а┬а┬а┬а┬а{format_source}",
			"format-source": "<span size='16pt' weight='600' rise='-4pt'>юМж</span>┬а{volume}%",
			"format-source-muted": "<span size='16pt' weight='600' rise='-4pt'>юМи</span>",
			"format-icons": {
				"default": [
					"юСФ",
					"юСТ",
					"юСТ",
					"юСТ",
					"юСР",
					"юСР",
					"юСР"
				]
			},
			"on-click": "pavucontrol",
			"on-click-right": "foot -a pw-top pw-top"
		},
		"custom/power": {
			"format": "<span size='17pt' rise='-4pt' weight='600'>юПЪ</span>",
			"tooltip": "Power Menu",
			"on-click": "~/.config/waybar/scripts/power-menu.sh"
		},
		"custom/theme": {
			"format": "<span size='12pt'>юК▓</span>",
			"format-icons": {
				"default": "юК▓"
			},
			"tooltip": "Toggle theme",
			"on-click": "~/.config/waybar/scripts/toggle-theme.sh"
		},
		"custom/battery": {
			"exec": "~/.config/waybar/scripts/battery.sh",
			"interval": 5,
			"return-type": "json",
			"tooltip": true
		},
		"custom/notification": {
			"tooltip": true,
			"format": "{icon}",
			"format-icons": {
				"notification": "юРл",
				"none": "",
				"dnd-notification": "ґ░Ва",
				"dnd-none": "ґ░кУ",
				"inhibited-notification": "юБЪ",
				"inhibited-none": "юБЪ",
				"dnd-inhibited-notification": "юБЪ",
				"dnd-inhibited-none": "юБЪ"
			},
			"return-type": "json",
			"exec-if": "which swaync-client",
			"exec": "swaync-client -swb",
			"on-click": "swaync-client -t -sw",
			"on-click-right": "swaync-client -d -sw",
			"escape": true
		}
	}
]
