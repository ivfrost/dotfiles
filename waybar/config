[
	{
		"layer": "top",
		"position": "top",
		"exclusive": true,
		"spacing": 4,
		"margin": 0,
		"modules-left": [
			"sway/workspaces",
			"sway/mode",
			"sway/window"
		],
		"modules-center": [
			"clock",
			"custom/notification"
		],
		"modules-right": [
			"sway/language",
			"tray",
			"keyboard-state",
			"mpd",
			"backlight",
			"pulseaudio",
			"custom/network",
			"custom/battery",
			"custom/power"
		],
		"sway/language": {
			"format": "{short}",
			"tooltip-format": "{long}",
			"on-click": "swaymsg input type:keyboard xkb_switch_layout next"
		},
		"keyboard-state": {
			"numlock": false,
			"capslock": true,
			"format": "{icon}",
			"format-icons": {
				"locked": "",
				"unlocked": ""
			},
			"empty-format": ""
		},
		"sway/workspaces": {
			"format": "<span size='12pt' rise='-19pt'>{icon}</span>",
			"all-outputs": true,
			"format-icons": {
				"1": "оВУ",
				"2": "оГ®",
				"3": "оЙЗ",
				"4": "оДЦ",
				"5": "оМЯ",
				"6": "оВА",
				"7": "оЪГ",
				"8": "оГХ",
				"9": "оБґ",
				"10": "оБґ"
			}
		},
		"sway/mode": {
			"format": "<span style=\"italic\">{}</span>"
		},
		"sway/scratchpad": {
			"format": "{icon} {count}",
			"show-empty": false,
			"format-icons": [
				"",
				"пЛТ"
			],
			"tooltip": true,
			"tooltip-format": "{app}: {title}"
		},
		"mpd": {
			"format": "пАБ  {title} - {artist} {stateIcon} [{elapsedTime:%M:%S}/{totalTime:%M:%S}] {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}[{songPosition}/{queueLength}] [{volume}%]",
			"format-disconnected": "пАБ Disconnected",
			"format-stopped": "пАБ {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped",
			"unknown-tag": "N/A",
			"interval": 2,
			"consume-icons": {
				"on": "пГД "
			},
			"random-icons": {
				"on": "пБі "
			},
			"repeat-icons": {
				"on": "пАЮ "
			},
			"single-icons": {
				"on": "пАЮ1 "
			},
			"state-icons": {
				"paused": "пБМ",
				"playing": "пБЛ"
			},
			"tooltip-format": "MPD (connected)",
			"tooltip-format-disconnected": "MPD (disconnected)",
			"on-click": "mpc toggle",
			"on-click-right": "foot -a ncmpcpp ncmpcpp",
			"on-scroll-up": "mpc volume +2",
			"on-scroll-down": "mpc volume -2"
		},
		"idle_inhibitor": {
			"format": "{icon}",
			"format-icons": {
				"activated": "пБЃ",
				"deactivated": "пБ∞"
			}
		},
		"tray": {
			"spacing": 10
		},
		"clock": {
			"format": "{:%a %d %b %H:%M}",
			"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
		},
		"cpu": {
			"format": "<span rise='-2pt' size='11pt'>{icon}</span> <span>{usage}%</span>",
			"format-icons": [
				"оВ©"
			]
		},
		"memory": {
			"format": "<span rise='-2pt' size='11pt'>оДХ</span> {}%"
		},
		"temperature": {
			"thermal-zone": 2,
			"hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
			"critical-threshold": 80,
			"format-critical": "{icon} {temperatureC}¬∞C",
			"format": "{icon} {temperatureC}¬∞C",
			"format-icons": [
				"пЭЂ",
				"пЛЙ",
				"пЭ©"
			]
		},
		"backlight": {
			"format": "<span rise='-4pt' size='13pt'>{icon}</span> {percent}%",
			"format-icons": [
				"оК±"
			],
			"tooltip": false
		},
		"custom/network": {
			"exec": "~/.config/waybar/scripts/network.sh",
			"interval": 5,
			"return-type": "json",
			"tooltip": true,
			"on-click": "nm-connection-editor"
		},
		"pulseaudio": {
			"scroll-step": 5,
			"format": "<span rise='-3.5pt' size='12pt'>{icon}</span>{volume}%¬†¬†¬†¬†¬†{format_source}",
			"format-bluetooth": "оБЬ {icon} {volume}% {format_source}",
			"format-bluetooth-muted": "пЪ© пКФ {icon} {format_source}",
			"format-muted": "<span rise='-3.5pt' size='12pt'>оШ¶</span>¬†¬†¬†¬†¬†{format_source}",
			"format-source": "<span rise='-3.5pt' size='12pt'>оДШ¬†</span>{volume}%",
			"format-source-muted": "<span rise='-3.5pt' size='12pt'>оДЩ</span>",
			"format-icons": {
				"default": [
					"оЖ™",
					"оЖЂ¬†"
				]
			},
			"on-click": "pavucontrol",
			"on-click-right": "foot -a pw-top pw-top"
		},
		"custom/power": {
			"format": "<span size='12pt'>оЕА</span>",
			"tooltip": "Power Menu",
			"on-click": "~/.config/waybar/scripts/power-menu.sh"
		},
		"custom/theme": {
			"format": "<span size='12pt'>оК≤</span>",
			"format-icons": {
				"default": "оК≤"
			},
			"tooltip": "Toggle theme",
			"on-click": "~/.config/waybar/scripts/toggle-theme.sh"
		},
		"custom/battery": {
			"exec": "~/.config/waybar/scripts/battery.sh",
			"interval": 5,
			"return-type": "json",
			"tooltip": true
		},
		"custom/notification": {
			"tooltip": true,
			"format": "{icon}",
			"format-icons": {
				"notification": "оРЂ",
				"none": "",
				"dnd-notification": "у∞В†",
				"dnd-none": "у∞™У",
				"inhibited-notification": "оБЪ",
				"inhibited-none": "оБЪ",
				"dnd-inhibited-notification": "оБЪ",
				"dnd-inhibited-none": "оБЪ"
			},
			"return-type": "json",
			"exec-if": "which swaync-client",
			"exec": "swaync-client -swb",
			"on-click": "swaync-client -t -sw",
			"on-click-right": "swaync-client -d -sw",
			"escape": true
		}
	}
]
