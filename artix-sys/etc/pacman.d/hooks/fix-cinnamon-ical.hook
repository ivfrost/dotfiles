[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = cinnamon

[Action]
Description = Fix ICal version in cinnamon-calendar-server
When = PostTransaction
Exec = /bin/sed -i "s/gi.require_version('ICal', '3.0')/gi.require_version('ICal', '4.0')/" /usr/lib/cinnamon/cinnamon-calendar-server.py
